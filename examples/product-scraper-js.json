[
  {
    "type": "useExcel",
    "config": {
      "path": "产品信息.xlsx",
      "variableList": ["SKU", "链接"],
      "variable": "products",
      "remark": "Import product data from Excel"
    }
  },
  {
    "type": "forLists",
    "config": {
      "content": "${products}",
      "variable": "product",
      "variableIndex": "productIndex",
      "children": [
        {
          "type": "extractKey",
          "config": {
            "content": "${product}",
            "key": "SKU",
            "variable": "sku",
            "remark": "Extract SKU"
          }
        },
        {
          "type": "extractKey",
          "config": {
            "content": "${product}",
            "key": "链接",
            "variable": "url",
            "remark": "Extract product URL"
          }
        },
        {
          "type": "gotoUrl",
          "config": {
            "url": "${url}",
            "timeout": 45000,
            "remark": "Open product page"
          }
        },
        {
          "type": "waitTime",
          "config": {
            "timeoutType": "randomInterval",
            "timeoutMin": 3000,
            "timeoutMax": 6000,
            "remark": "Wait for page to load"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": [],
            "content": "let result={};try{let priceEl=document.evaluate('//div[@data-fusion-component=\"@thd-olt-component-react/price\"]',document,null,XPathResult.FIRST_ORDERED_NODE_TYPE,null).singleNodeValue;result.price=priceEl?priceEl.textContent.trim():''}catch(e){result.price=''};try{let shipEl=document.evaluate('//div[@class=\"sui-grid-cols-12\"]/div',document,null,XPathResult.FIRST_ORDERED_NODE_TYPE,null).singleNodeValue;result.shipmethod=shipEl?shipEl.textContent.trim():''}catch(e){result.shipmethod=''};try{let buyboxEl=document.evaluate('//div[@data-component=\"buybox:BuyboxActions:v5.134.0\"]',document,null,XPathResult.FIRST_ORDERED_NODE_TYPE,null).singleNodeValue;result.buybox=buyboxEl?buyboxEl.textContent.trim():''}catch(e){result.buybox=''};try{let qnaEl=document.evaluate('//div[@id=\"product-section-qa\"]',document,null,XPathResult.FIRST_ORDERED_NODE_TYPE,null).singleNodeValue;result.QnA=qnaEl?qnaEl.textContent.trim():''}catch(e){result.QnA=''};try{let reviewEl=document.evaluate('//div[@id=\"product-section-rr\"]',document,null,XPathResult.FIRST_ORDERED_NODE_TYPE,null).singleNodeValue;result.Review=reviewEl?reviewEl.textContent.trim():''}catch(e){result.Review=''};return JSON.stringify(result);",
            "srcContent": "let result = {};\n\n// Get price\ntry {\n  let priceEl = document.evaluate('//div[@data-fusion-component=\"@thd-olt-component-react/price\"]', document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;\n  result.price = priceEl ? priceEl.textContent.trim() : '';\n} catch(e) { result.price = ''; }\n\n// Get shipping method\ntry {\n  let shipEl = document.evaluate('//div[@class=\"sui-grid-cols-12\"]/div', document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;\n  result.shipmethod = shipEl ? shipEl.textContent.trim() : '';\n} catch(e) { result.shipmethod = ''; }\n\n// Get buybox\ntry {\n  let buyboxEl = document.evaluate('//div[@data-component=\"buybox:BuyboxActions:v5.134.0\"]', document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;\n  result.buybox = buyboxEl ? buyboxEl.textContent.trim() : '';\n} catch(e) { result.buybox = ''; }\n\n// Get QnA\ntry {\n  let qnaEl = document.evaluate('//div[@id=\"product-section-qa\"]', document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;\n  result.QnA = qnaEl ? qnaEl.textContent.trim() : '';\n} catch(e) { result.QnA = ''; }\n\n// Get Reviews\ntry {\n  let reviewEl = document.evaluate('//div[@id=\"product-section-rr\"]', document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;\n  result.Review = reviewEl ? reviewEl.textContent.trim() : '';\n} catch(e) { result.Review = ''; }\n\nreturn JSON.stringify(result);",
            "variable": "productData",
            "remark": "Extract all product info using JavaScript"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": ["productData"],
            "content": "let data=JSON.parse(productData);return data.price",
            "srcContent": "let data = JSON.parse(productData);\nreturn data.price;",
            "variable": "price",
            "remark": "Extract price from JSON"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": ["productData"],
            "content": "let data=JSON.parse(productData);return data.shipmethod",
            "srcContent": "let data = JSON.parse(productData);\nreturn data.shipmethod;",
            "variable": "shipmethod",
            "remark": "Extract shipping method from JSON"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": ["productData"],
            "content": "let data=JSON.parse(productData);return data.buybox",
            "srcContent": "let data = JSON.parse(productData);\nreturn data.buybox;",
            "variable": "buybox",
            "remark": "Extract buybox from JSON"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": ["productData"],
            "content": "let data=JSON.parse(productData);return data.QnA",
            "srcContent": "let data = JSON.parse(productData);\nreturn data.QnA;",
            "variable": "QnA",
            "remark": "Extract QnA from JSON"
          }
        },
        {
          "type": "javaScript",
          "config": {
            "params": ["productData"],
            "content": "let data=JSON.parse(productData);return data.Review",
            "srcContent": "let data = JSON.parse(productData);\nreturn data.Review;",
            "variable": "Review",
            "remark": "Extract reviews from JSON"
          }
        },
        {
          "type": "saveToExcel",
          "config": {
            "filename": "产品抓取结果.xlsx",
            "columns": ["sku", "url", "price", "shipmethod", "buybox", "QnA", "Review"],
            "remark": "Save extracted data to Excel"
          }
        },
        {
          "type": "waitTime",
          "config": {
            "timeoutType": "randomInterval",
            "timeoutMin": 2000,
            "timeoutMax": 4000,
            "remark": "Wait before next product"
          }
        }
      ],
      "remark": "Loop through each product"
    }
  }
]
