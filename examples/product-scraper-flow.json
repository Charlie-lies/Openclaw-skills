{
  "name": "Product Data Scraper - SKU Price Reviews",
  "description": "Extract product price, shipping method, buybox, QnA and reviews from product URLs",
  "steps": [
    {
      "action": "importExcel",
      "path": "产品信息.xlsx",
      "variableList": ["SKU", "链接"],
      "variable": "products",
      "remark": "Import product data from Excel"
    },
    {
      "action": "forData",
      "data": "${products}",
      "saveTo": "product",
      "saveIndexTo": "productIndex",
      "remark": "Loop through each product",
      "do": [
        {
          "action": "getField",
          "data": "${product}",
          "key": "SKU",
          "saveTo": "sku",
          "remark": "Extract SKU"
        },
        {
          "action": "getField",
          "data": "${product}",
          "key": "链接",
          "saveTo": "url",
          "remark": "Extract product URL"
        },
        {
          "action": "visit",
          "url": "${url}",
          "remark": "Open product page",
          "timeout": 45000
        },
        {
          "action": "wait",
          "timeoutType": "random",
          "timeoutMin": 3000,
          "timeoutMax": 6000,
          "remark": "Wait for page to load"
        },
        {
          "action": "extract",
          "selector": "//div[@data-fusion-component='@thd-olt-component-react/price']",
          "selectorType": "xpath",
          "extractType": "text",
          "saveTo": "price",
          "remark": "Extract price"
        },
        {
          "action": "extract",
          "selector": "//div[@class='sui-grid-cols-12']/div",
          "selectorType": "xpath",
          "extractType": "text",
          "saveTo": "shipmethod",
          "remark": "Extract shipping method"
        },
        {
          "action": "extract",
          "selector": "//div[@data-component='buybox:BuyboxActions:v5.134.0']",
          "selectorType": "xpath",
          "extractType": "text",
          "saveTo": "buybox",
          "remark": "Extract buybox info"
        },
        {
          "action": "extract",
          "selector": "//div[@id='product-section-qa']",
          "selectorType": "xpath",
          "extractType": "text",
          "saveTo": "QnA",
          "remark": "Extract QnA section"
        },
        {
          "action": "extract",
          "selector": "//div[@id='product-section-rr']",
          "selectorType": "xpath",
          "extractType": "text",
          "saveTo": "Review",
          "remark": "Extract reviews section"
        },
        {
          "action": "saveExcel",
          "filename": "产品抓取结果.xlsx",
          "columns": ["sku", "url", "price", "shipmethod", "buybox", "QnA", "Review"],
          "remark": "Save extracted data to Excel"
        },
        {
          "action": "wait",
          "timeoutType": "random",
          "timeoutMin": 2000,
          "timeoutMax": 4000,
          "remark": "Wait before next product"
        }
      ]
    },
    {
      "action": "setRemark",
      "content": "Product scraping completed",
      "mode": "append",
      "remark": "Update environment remark"
    }
  ]
}
