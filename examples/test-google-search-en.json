{
  "name": "Test - Google Search Automation",
  "description": "Test case: Automatically visit Google and perform search",
  "steps": [
    {
      "action": "visit",
      "url": "https://www.google.com",
      "remark": "Open Google homepage"
    },
    {
      "action": "wait",
      "timeoutType": "random",
      "timeoutMin": 1500,
      "timeoutMax": 3000,
      "remark": "Random wait 1.5-3 seconds"
    },
    {
      "action": "input",
      "selector": "textarea[name='q']",
      "content": "AdsPower RPA automation",
      "clearInput": true,
      "intervals": 50,
      "remark": "Type search keyword"
    },
    {
      "action": "wait",
      "timeoutType": "random",
      "timeoutMin": 800,
      "timeoutMax": 1500,
      "remark": "Simulate human typing interval"
    },
    {
      "action": "key",
      "key": "Enter",
      "remark": "Press Enter to search"
    },
    {
      "action": "waitFor",
      "selector": "#search",
      "timeout": 10000,
      "remark": "Wait for search results"
    },
    {
      "action": "scroll",
      "position": "bottom",
      "scrollType": "smooth",
      "remark": "Scroll to bottom"
    },
    {
      "action": "wait",
      "timeoutType": "random",
      "timeoutMin": 2000,
      "timeoutMax": 4000,
      "remark": "Stay and browse"
    },
    {
      "action": "screenshot",
      "name": "google_search_result",
      "fullScreen": true,
      "format": "png",
      "remark": "Screenshot results"
    }
  ]
}
