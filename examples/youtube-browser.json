{
  "name": "YouTube Video Browser",
  "description": "Browse random YouTube videos from search",
  "steps": [
    {
      "action": "importTxt",
      "path": "C:/data/keywords.txt",
      "variable": "keywords"
    },
    {
      "action": "randomPick",
      "data": "${keywords}",
      "saveTo": "keyword"
    },
    {
      "action": "visit",
      "url": "https://www.youtube.com"
    },
    {
      "action": "wait",
      "timeoutType": "random",
      "timeoutMin": 3000,
      "timeoutMax": 5000
    },
    {
      "action": "input",
      "selector": "input[name='search_query']",
      "content": "${keyword}"
    },
    {
      "action": "key",
      "key": "Enter"
    },
    {
      "action": "wait",
      "timeout": 5000
    },
    {
      "action": "forCount",
      "count": 3,
      "saveIndexTo": "videoNum",
      "do": [
        {
          "action": "forElements",
          "selector": "ytd-video-renderer",
          "serialMin": 1,
          "serialMax": 5,
          "saveTo": "video"
        },
        {
          "action": "click",
          "element": "${video}"
        },
        {
          "action": "wait",
          "timeoutType": "random",
          "timeoutMin": 8000,
          "timeoutMax": 15000
        },
        {
          "action": "scroll",
          "position": "bottom",
          "scrollType": "smooth"
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "goBack"
        },
        {
          "action": "wait",
          "timeout": 3000
        }
      ]
    }
  ]
}
