{
  "name": "Multi-Platform Social Media Poster",
  "description": "Post content to multiple social media platforms with data import",
  "steps": [
    {
      "action": "importExcel",
      "path": "C:/data/posts.xlsx",
      "variableList": ["platform", "content", "image_path"],
      "variable": "posts"
    },
    {
      "action": "forData",
      "data": "${posts}",
      "saveTo": "post",
      "saveIndexTo": "postIndex",
      "do": [
        {
          "action": "getField",
          "data": "${post}",
          "key": "platform",
          "saveTo": "platformName"
        },
        {
          "action": "getField",
          "data": "${post}",
          "key": "content",
          "saveTo": "postContent"
        },
        {
          "action": "getField",
          "data": "${post}",
          "key": "image_path",
          "saveTo": "imagePath"
        },
        {
          "action": "if",
          "variable": "platformName",
          "condition": "eq",
          "value": "twitter",
          "then": [
            {
              "action": "visit",
              "url": "https://twitter.com/compose/tweet"
            },
            {
              "action": "wait",
              "timeoutType": "random",
              "timeoutMin": 2000,
              "timeoutMax": 4000
            },
            {
              "action": "input",
              "selector": "div[data-testid='tweetTextarea_0']",
              "content": "${postContent}",
              "intervals": 30
            },
            {
              "action": "if",
              "variable": "imagePath",
              "condition": "neq",
              "value": "",
              "then": [
                {
                  "action": "upload",
                  "selector": "input[type='file']",
                  "filePath": "${imagePath}"
                }
              ]
            },
            {
              "action": "wait",
              "timeoutType": "random",
              "timeoutMin": 1000,
              "timeoutMax": 2000
            },
            {
              "action": "click",
              "selector": "div[data-testid='tweetButton']"
            }
          ]
        },
        {
          "action": "if",
          "variable": "platformName",
          "condition": "eq",
          "value": "facebook",
          "then": [
            {
              "action": "visit",
              "url": "https://facebook.com"
            },
            {
              "action": "wait",
              "timeout": 5000
            },
            {
              "action": "click",
              "selector": "[aria-label='Create a post']"
            },
            {
              "action": "wait",
              "timeout": 2000
            },
            {
              "action": "input",
              "selector": "[role='dialog'] [contenteditable='true']",
              "content": "${postContent}"
            },
            {
              "action": "wait",
              "timeoutType": "random",
              "timeoutMin": 2000,
              "timeoutMax": 3000
            },
            {
              "action": "click",
              "selector": "[aria-label='Post']"
            }
          ]
        },
        {
          "action": "wait",
          "timeoutType": "random",
          "timeoutMin": 3000,
          "timeoutMax": 5000
        },
        {
          "action": "screenshot",
          "name": "post_${platformName}_${postIndex}",
          "fullScreen": false,
          "format": "png"
        },
        {
          "action": "setRemark",
          "content": "Posted to ${platformName}",
          "mode": "append"
        }
      ]
    }
  ]
}
